{
  "$schema": "https://json-schema.org/draft-07/schema",
  "$id": "https://example.org/deaconizer/nextflow_schema.json",
  "title": "deaconizer pipeline parameters",
  "type": "object",
  "definitions": {
    "input_output_options": {
      "title": "Input/output options",
      "type": "object",
      "required": ["input", "db"],
      "properties": {
        "input": {
          "type": "string",
          "description": "CSV samplesheet with columns sample_id, reads_r1, reads_r2."
        },
        "ref": {
          "type": "string",
          "description": "Reference FASTA used to build the Deacon minimizer index. Required unless --index is provided; mutually exclusive with --index."
        },
        "index": {
          "type": "string",
          "description": "Path to a pre-built Deacon index file (e.g. produced by makedb.nf), used instead of building one from --ref. Required unless --ref is provided; mutually exclusive with --ref."
        },
        "db": {
          "type": "string",
          "description": "Kraken2 database directory."
        },
        "list": {
          "type": "string",
          "description": "makedb.nf only: optional CSV with columns id,fasta_path listing genomes whose minimizers should be masked out of the reference index."
        },
        "outdir": {
          "type": "string",
          "default": "results",
          "description": "Output directory."
        }
      }
    },
    "deacon_options": {
      "title": "Deacon options",
      "type": "object",
      "properties": {
        "deacon_kmer_length": {
          "type": "integer",
          "default": 31
        },
        "deacon_window_size": {
          "type": "integer",
          "default": 15
        },
        "deacon_entropy_threshold": {
          "type": "number",
          "default": 0.0
        },
        "deacon_abs_threshold": {
          "type": "integer",
          "default": 1
        },
        "deacon_rel_threshold": {
          "type": "number",
          "default": 0.0
        },
        "deacon_prefix_length": {
          "type": "integer",
          "default": 0
        },
        "deacon_deplete": {
          "type": "boolean",
          "default": true
        },
        "deacon_filter_args": {
          "type": "string",
          "default": ""
        },
        "deacon_read_type": {
          "type": "string",
          "default": ""
        }
      }
    },
    "kraut_options": {
      "title": "Kraut options",
      "type": "object",
      "properties": {
        "kraut_rank": {
          "type": "string",
          "default": "S",
          "description": "Taxonomic rank for kraut make-table/plot-multi (K/P/C/O/F/G/S/ALL)."
        },
        "kraut_metric": {
          "type": "string",
          "default": "TOT",
          "description": "Measurement type for kraut make-table/plot-multi (LVL/TOT/PERCENTAGE)."
        },
        "kraut_maketable_args": {
          "type": "string",
          "default": ""
        },
        "kraut_plotmulti_args": {
          "type": "string",
          "default": ""
        },
        "kraut_plot_kind": {
          "type": "string",
          "default": "",
          "description": "kraut plot-multi chart style: bar (default) or bubble."
        },
        "kraut_plot_ext": {
          "type": "string",
          "default": "png",
          "description": "Extension of the kraut plot-multi output file. Use html when kraut_plot_kind is bubble."
        }
      }
    },
    "runtime_options": {
      "title": "Runtime options",
      "type": "object",
      "properties": {
        "fastp_args": {
          "type": "string",
          "default": ""
        },
        "kraken2_args": {
          "type": "string",
          "default": ""
        },
        "multiqc_args": {
          "type": "string",
          "default": ""
        },
        "multiqc_config": {
          "type": "string",
          "description": "MultiQC custom configuration YAML."
        },
        "k8s_storage_claim_name": {
          "type": "string"
        },
        "k8s_storage_mount_path": {
          "type": "string",
          "default": "/workspace"
        },
        "k8s_storage_sub_path": {
          "type": "string",
          "default": "/"
        }
      }
    }
  },
  "allOf": [
    { "$ref": "#/definitions/input_output_options" },
    { "$ref": "#/definitions/deacon_options" },
    { "$ref": "#/definitions/kraut_options" },
    { "$ref": "#/definitions/runtime_options" }
  ]
}
